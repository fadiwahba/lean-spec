{
  "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/lean-spec/remind-manual-workflow.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Agent|Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/lean-spec/enforce-manual-workflow.sh",
          "timeout": 10
        }
      ]
    }
  ]
}
