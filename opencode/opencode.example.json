{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    ".opencode/LEAN_SPEC_INSTRUCTIONS.md"
  ],
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm": "ask"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "sequential_thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  }
}
